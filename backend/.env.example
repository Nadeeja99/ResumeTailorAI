GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001

# Stripe – required for freemium billing
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Create a recurring price in Stripe Dashboard and paste its ID here (e.g. price_xxx)
STRIPE_PRO_PRICE_ID=your_stripe_price_id_here
# Run `stripe listen --forward-to localhost:3001/api/billing/webhook` to get this
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
